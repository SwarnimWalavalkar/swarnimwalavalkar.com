---
import type { CollectionEntry } from "astro:content";
import { formatDate } from "../lib/date";
import { Link } from "./Link";

type Props = {
  post: CollectionEntry<"posts">;
};

const {
  post: {
    data: { title, description, date, tags },
    slug,
  },
} = Astro.props;
---

<article class="group">
  <Link href={`/posts/${slug}`} noUnderline>
    <div class="flex items-baseline justify-between gap-4">
      <span class="text-base font-semibold text-neutral-200 group-hover:text-white transition-colors duration-200">{title}</span>
      <span class="shrink-0 text-sm text-neutral-600 tabular-nums">{formatDate(date)}</span>
    </div>
    {tags.length > 0 && (
      <div class="mt-1.5 flex gap-2">
        {tags.map((tag) => (
          <span class="text-xs text-neutral-600">{tag}</span>
        ))}
      </div>
    )}
  </Link>
</article>
