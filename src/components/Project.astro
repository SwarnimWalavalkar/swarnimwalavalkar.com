---
import type { Project } from "../lib/projects";

type Props = {
  project: Project;
};

const {
  project: { name, description, repoURL },
} = Astro.props;
---

<a
  href={repoURL}
  target="_blank"
  class="group flex flex-col rounded-lg border border-neutral-800/60 p-4 transition-all duration-200 hover:border-neutral-700 hover:bg-neutral-900/30"
>
  <span class="font-medium text-neutral-200 group-hover:text-neutral-100 transition-colors duration-200">{name}</span>
  <span class="mt-2 text-sm text-neutral-500 leading-relaxed">{description}</span>
</a>
